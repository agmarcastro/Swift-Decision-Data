# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL — admin user (used only by seed.py and qdrant_ingest)
POSTGRES_ADMIN_URL=postgresql://infoagent_admin:changeme@localhost:5432/infoagent

# PostgreSQL — read-only user (used by sql_tool in the agent layer)
POSTGRES_READONLY_URL=postgresql://infoagent_readonly:readonly_changeme@localhost:5432/infoagent

# PostgreSQL credentials (used by docker-compose)
POSTGRES_DB=infoagent
POSTGRES_USER=infoagent_admin
POSTGRES_PASSWORD=changeme
POSTGRES_READONLY_PASSWORD=readonly_changeme

# LangFuse — observability dashboard (local Docker container)
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_NEXTAUTH_SECRET=changeme_nextauth
LANGFUSE_SALT=changeme_salt
