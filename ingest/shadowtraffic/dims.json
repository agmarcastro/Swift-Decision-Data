          ]
        },
        "faixa_etaria": {
          "_gen": "oneOf",
          "choices": ["18-24", "25-34", "35-44", "45-54", "55+"]
        }
      },
      "localConfigs": {
        "maxEvents": 1000,
        "maxHistoryEvents": 1000
