    {
      "table": "dim_tempo",
      "row": {
        "data": {
          "_gen": "formatDateTime",
          "ms": {
            "_gen": "sequentialInteger",
            "startingFrom": 1704067200000,
            "step": 86400000
          },
          "format": "yyyy-MM-dd"
        },
        "dia_semana": {
          "_gen": "weightedOneOf",
          "choices": [
