        },
        "ano": {
          "_gen": "weightedOneOf",
          "choices": [
            { "weight": 50, "value": 2024 },
            { "weight": 50, "value": 2025 }
          ]
        },
        "flg_feriado": {
          "_gen": "weightedOneOf",
          "choices": [
            { "weight": 967, "value": false },
            { "weight": 33,  "value": true }
          ]
        }
      },
      "localConfigs": {
        "maxEvents": 730,
        "maxHistoryEvents": 730
      }
    }
