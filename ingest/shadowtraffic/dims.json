{
  "generators": [
    {
      "table": "dim_produto",
      "row": {
        "sku": {
          "_gen": "string",
          "expr": "SKU-#{Number.number_between '100000','999999'}"
        },
        "departamento": {
          "_gen": "weightedOneOf",
          "choices": [
            { "weight": 20, "value": "Computing" },
            { "weight": 25, "value": "Telephony" },
            { "weight": 15, "value": "TV/Audio" },
            { "weight": 15, "value": "Gaming" },
            { "weight": 15, "value": "Home Appliances" },
            { "weight": 10, "value": "Printing" }
          ]
        },
        "categoria": {
          "_gen": "weightedOneOf",
          "choices": [
            { "weight": 7,  "value": "notebook" },
            { "weight": 7,  "value": "desktop" },
            { "weight": 6,  "value": "monitor" },
            { "weight": 8,  "value": "smartphone premium" },
            { "weight": 9,  "value": "smartphone" },
            { "weight": 8,  "value": "tablet" },
