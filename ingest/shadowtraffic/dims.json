            "Samsung", "LG", "Apple", "Sony", "Dell", "Lenovo", "HP", "Asus",
            "Acer", "Microsoft", "Motorola", "Xiaomi", "Philips", "Multilaser",
            "Positivo", "Electrolux", "Brastemp", "Epson", "Canon", "Brother"
          ]
        },
        "nome_produto": {
          "_gen": "string",
          "expr": "#{Commerce.product_name} #{Number.number_between '2020','2025'}"
        }
      },
      "localConfigs": {
        "maxEvents": 200,
        "maxHistoryEvents": 200
      }
    },
    {
      "table": "dim_cliente",
      "row": {
